rules_version = '2';

// Collaborator emails are stored in lowercase (see firestore.js shareFloorPlan).
// request.auth.token.email from Google Sign-In is typically lowercase; if not, sharing may need to match.

service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: signed-in users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Floor plans: create = any signed-in user; read/update = owner or collaborator; delete = owner only
    match /floorplans/{planId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (resource.data.get('createdBy', '') == request.auth.uid
            || resource.data.get('ownerEmail', '') == request.auth.token.email
            || request.auth.token.email in resource.data.get('collaboratorEmails', []));
      allow update: if request.auth != null
        && (resource.data.get('createdBy', '') == request.auth.uid
            || resource.data.get('ownerEmail', '') == request.auth.token.email
            || (request.auth.token.email in resource.data.get('collaboratorEmails', [])
                && resource.data.get('collaborators', {}).get(request.auth.token.email, '') == 'editor'));
      allow delete: if request.auth != null
        && (resource.data.get('createdBy', '') == request.auth.uid
            || resource.data.get('ownerEmail', '') == request.auth.token.email);
    }
  }
}
